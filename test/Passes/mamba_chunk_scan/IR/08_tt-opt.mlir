              }
              loom.semaphore_give %72 : memref<f16>
              loom.semaphore_give %74 : memref<64x32xf16>
              loom.semaphore_give %33 : memref<64x32xf16>
              %reinterpret_cast_4 = memref.reinterpret_cast %arg7 to offset: [%80], sizes: [64, 32], strides: [160, 1] : memref<2x32x1536x160xf16> to memref<64x32xf16, strided<[160, 1], offset: ?>>
              loom.copy %82, %reinterpret_cast_4 src_mem_space @mem_L1 dst_mem_space @mem_DRAM, area : [1, 1] region : (UL : [%arg8, %arg9], LR : [%arg8, %arg9]) : memref<64x32xf16> to memref<64x32xf16, strided<[160, 1], offset: ?>>
              loom.semaphore_give %82 : memref<64x32xf16>
            } {loom.iter_type = #loom.iter_type<sequential>}
          } {loom.iter_type = #loom.iter_type<sequential>}
        } {loom.block_sym = @tile_m, loom.iter_type = #loom.iter_type<temporal>}
        scf.reduce 
      } {loom.block_syms = [@tile_n, @tile_n], loom.iter_types = [#loom.iter_type<spatial>, #loom.iter_type<spatial>], loom.logical_levels = [0, 0], loom.physical_dims = [@dim_x, @dim_y]}
      return
    }
  }
}
