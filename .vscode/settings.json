{
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
    "C_Cpp.default.compileCommands": "${workspaceFolder}/build/compile_commands.json",
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/lib",
        "${workspaceFolder}/build/_deps/googletest-src/googletest/include",
        "${workspaceFolder}/build/_deps/googletest-src/googlemock/include"
    ],
    "C_Cpp.default.defines": [],
    "C_Cpp.default.cStandard": "c17",
    "C_Cpp.default.cppStandard": "c++17",
    "C_Cpp.default.intelliSenseMode": "linux-gcc-x64",
    "C_Cpp.errorSquiggles": "enabled",
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.configureOnOpen": true,
    "cmake.generator": "Ninja",
    "files.associations": {
        "*.h": "cpp",
        "*.cpp": "cpp",
        "*.hpp": "cpp"
    },
    "cmake.configureSettings": {
        "MLIR_DIR": "/opt/llvm-mlir/lib/cmake/mlir",
        "LLVM_USE_LINKER": "lld",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
    },
    "mlir.server_path": "/root/loom-dataflow/build/tool/loom-lsp-server/loom-lsp-server",
    "mlir.pdll_server_path": "/opt/llvm-mlir/bin/mlir-pdll-lsp-server",
    "mlir.tablegen_server_path": "/opt/llvm-mlir/bin/tblgen-lsp-server"
}